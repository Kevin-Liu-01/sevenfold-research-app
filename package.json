{
    "name": "harbor",
    "private": true,
    "scripts": {
        "build": "turbo run build",
        "dev": "turbo run dev",
        "lint": "turbo run lint",
        "commit": "git cz",
        "format": "prettier --write \"**/*.{ts,tsx,md}\"",
        "check-types": "turbo run check-types"
    },
    "devDependencies": {
        "commitizen": "^4.3.1",
        "cz-conventional-changelog": "^3.3.0",
        "prettier": "^3.6.2",
        "turbo": "^2.5.5",
        "typescript": "5.8.3"
    },
    "packageManager": "pnpm@9.0.0",
    "engines": {
        "node": ">=18"
    },
    "config": {
        "commitizen": {
            "path": "./node_modules/cz-conventional-changelog"
        }
    }
}