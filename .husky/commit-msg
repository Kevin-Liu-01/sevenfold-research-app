pnpm commitlint --edit "$1"

if [ $? -ne 0 ]; then
  echo ""
  echo "Commit message does not follow Conventional Commits format."
  echo ""
  echo "🔧 Example:"
  echo "  feat: add new dashboard layout"
  echo "  fix: resolve login crash on Safari"
  echo ""
  echo "💡 Use 'pnpm commit' for a guided commit message wizard."
  exit 1
fi